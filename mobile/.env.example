# TamamHealth Patient mobile app — environment variables
#
# Anything prefixed `EXPO_PUBLIC_` is bundled into the JS at build time and
# is therefore READABLE to anyone with the .apk / .ipa. Never put real
# secrets here — only public configuration the client legitimately needs.
#
# To use locally:
#   cp .env.example .env
#   then edit values, then run `npm run dev`

# Base URL of the TamamHealth platform API.
#  - Local dev (Next.js dev server on host machine): http://localhost:3000
#  - Local dev on a physical phone over LAN:        http://<your-machine-ip>:3000
#  - Staging / production:                          https://api.tamamhealth.org
#
# A trailing slash is fine; the api-client strips it.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Demo mode. Anything other than the literal string `false` enables:
#   - Seed data (Deng Mabior Garang + family) loaded into local SQLite.
#   - Demo accounts shown on the Login screen below the form.
# Production builds MUST set this to `false` so:
#   1. Patients never see another patient's records by default.
#   2. The login screen doesn't leak example hospital numbers.
EXPO_PUBLIC_DEMO_MODE=true
