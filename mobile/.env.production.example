# TamamHealth Patient mobile app — production environment variables.
#
# This file documents the values an EAS build profile or release CI job
# should inject into the runtime. EAS reads these out of eas.json's
# `build.production.env` block (or from a `.env.production` if you've set
# `expo-env-info` to read it); copy these values into whichever surface
# your release pipeline uses.

# Production platform API. Patient app talks to /api/patient-portal/* only.
EXPO_PUBLIC_API_BASE_URL=https://api.tamamhealth.org

# Demo mode MUST be `false` in production builds.
#
# When `false`:
#  - Local SQLite is not seeded with the example pat-00001 records.
#  - Login screen hides the demo-accounts list.
#
# Anything else (or unset) enables demo data — appropriate for internal
# preview / EAS preview channels, NEVER for the App Store / Play Store track.
EXPO_PUBLIC_DEMO_MODE=false
