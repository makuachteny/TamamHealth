# =============================================================================
# TamamHealth Platform — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Or run the setup script which does this automatically:
#   npm run setup
# =============================================================================

# --- Mode ---
# "true"  = seeds demo patients, hospitals, users for testing (default)
# "false" = production mode — no demo data, creates single admin user
NEXT_PUBLIC_DEMO_MODE=true

# --- Production Setup (only when DEMO_MODE=false) ---
# Initial admin display name (safe to expose to the browser).
NEXT_PUBLIC_ADMIN_NAME=System Administrator

# Initial admin password — server-only. NOT NEXT_PUBLIC_*: the browser must
# never see this. If you leave it unset, the platform generates a random
# admin password on first boot and writes it to .seed-credentials.json
# (see lib/seed-credentials.ts). Either way, change it the moment you log in.
# ADMIN_INITIAL_PASSWORD=

# Organization details
NEXT_PUBLIC_ORG_NAME=My Organization
NEXT_PUBLIC_ORG_EMAIL=admin@organization.org
NEXT_PUBLIC_ORG_COUNTRY=South Sudan

# --- Auth ---
# JWT secret for session tokens. MUST be changed in production.
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Or on Linux/macOS:        openssl rand -base64 48
NEXT_PUBLIC_JWT_SECRET=change-me-to-a-random-secret

# Server-side JWT secret (takes precedence over NEXT_PUBLIC_JWT_SECRET)
# Recommended for production — keeps the secret out of the browser bundle.
# JWT_SECRET=

# --- PostgreSQL (National Analytics Database) ---
# Server-side only — never exposed to the browser.
# Required for national-level analytics, government dashboards, and cross-facility reporting.
# If not set, the app still works fully via local PouchDB (browser IndexedDB).
DATABASE_URL=postgresql://tamamhealth:password@localhost:5432/safeguard_junub

# --- CouchDB Sync (Optional) ---
# Enable PouchDB <-> CouchDB live replication for multi-facility sync.
# When "false" the app works fully offline with local PouchDB only.
NEXT_PUBLIC_SYNC_ENABLED=false

# CouchDB server URL (include credentials for authenticated access)
NEXT_PUBLIC_COUCHDB_URL=http://localhost:5984

# CouchDB admin credentials (used by setup script)
COUCHDB_ADMIN_USER=admin
COUCHDB_ADMIN_PASSWORD=TamamHealth4Lyf

# CouchDB webhook signing secret — required if sync is enabled.
# Used to verify /api/sync webhook requests from CouchDB.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# COUCHDB_WEBHOOK_SECRET=

# --- Server-side CouchDB access (for /api/* routes) ---
# The platform API routes talk to CouchDB directly over the internal network.
# Separate from NEXT_PUBLIC_COUCHDB_URL (which is what the BROWSER hits).
# In docker-compose, this is http://couchdb:5984; in bare dev, http://localhost:5984.
# COUCHDB_URL=http://localhost:5984
# COUCHDB_ADMIN_USER=admin
# COUCHDB_ADMIN_PASSWORD=

# --- Email (Optional) ---
# For contact forms, demo requests, and notifications.
# EMAIL_PROVIDER picks the backend: "resend" | "sendgrid" | "smtp" | "" (disabled)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# FROM_EMAIL=noreply@tamamhealth.org
# DEMO_FROM_EMAIL=noreply@tamamhealth.org
# DEMO_FROM_NAME=TamamHealth
# DEMO_NOTIFY_EMAIL=your-email@example.com

# --- Payments (Optional) ---
# Webhook secrets for payment providers
# FLUTTERWAVE_SECRET_HASH=

# --- App URL ---
# Base URL for generating payment links and external URLs
# NEXT_PUBLIC_APP_URL=https://app.tamamhealth.org

# --- Localization defaults ---
# 3-letter ISO 4217 currency code used as the default for ledger entries and
# payment links when the caller doesn't supply one. Defaults to SSP.
# NEXT_PUBLIC_DEFAULT_CURRENCY=SSP

# Default 3-letter prefix used in patient hospital-number generation when a
# facility doesn't have its own `code` field and the ID doesn't match the
# `phcc-` / `phcu-` / `county-` structural patterns. Defaults to TAB.
# NEXT_PUBLIC_HOSPITAL_NUMBER_DEFAULT_PREFIX=TAB

# Login screen subtitle/footer overrides. Defaults derive from
# NEXT_PUBLIC_ORG_COUNTRY ("Republic of <country> · Ministry of Health · v2.0").
# NEXT_PUBLIC_LOGIN_FOOTER=

# --- FHIR namespace ---
# Base URI used for FHIR identifier.system fields (hospital number, geocode,
# national ID) and CodeSystem/ValueSet `url` fields emitted by /api/terminology.
# Should be a domain you own. Defaults to https://tamamhealth.org.
# NEXT_PUBLIC_FHIR_NAMESPACE_BASE=https://tamamhealth.org

# --- DHIS2 export (Optional) ---
# National health information system endpoint. The code reads
# NEXT_PUBLIC_DHIS2_BASE_URL (or DHIS2_BASE_URL on the server side); legacy
# `NEXT_PUBLIC_DHIS` is no longer recognized.
# NEXT_PUBLIC_DHIS2_BASE_URL=https://hmis.southsudan.health
# DHIS2_BASE_URL=https://hmis.southsudan.health      # server-side override
# DHIS2_USER=
# DHIS2_PASSWORD=
# DHIS2_PAT=

# --- License (Optional) ---
# HMAC secret + signed license key for offline license verification.
# Generate secret: openssl rand -hex 32
# TAMAMHEALTH_LICENSE_SECRET=
# TAMAMHEALTH_LICENSE_KEY=

# --- Observability / Sentry (Optional) ---
# When unset, Sentry init is a no-op everywhere (this is the dev default —
# you do NOT need a Sentry account to run the platform locally).
#
# SENTRY_DSN              — server-side DSN. Used by sentry.server.config.ts
#                           and sentry.edge.config.ts. NOT exposed to browser.
# NEXT_PUBLIC_SENTRY_DSN  — browser DSN. Baked into the client bundle at build
#                           time. Usually identical to SENTRY_DSN (one Sentry
#                           project covers both halves).
# SENTRY_RELEASE          — optional release identifier; tags every event.
#                           Defaults to NEXT_PUBLIC_BUILD_ID-style timestamp.
#
# See docs/operations/monitoring.md for the PII-stripping policy and the
# uptime / alerting setup.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_RELEASE=
