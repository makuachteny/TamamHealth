# =============================================================================
# TamamHealth Platform — PRODUCTION environment
# =============================================================================
# Copy to .env.production BEFORE running `docker compose build`:
#   cp platform/.env.production.example platform/.env.production
#
# IMPORTANT: NEXT_PUBLIC_* values are baked into the browser bundle at
# BUILD time. Set them here, then rebuild the image whenever they change.
# Server-only secrets (JWT_SECRET, DATABASE_URL, etc.) are read at runtime.
# =============================================================================

# --- Mode ---
NEXT_PUBLIC_DEMO_MODE=false

# --- Admin bootstrap (used on first run when DEMO_MODE=false) ---
NEXT_PUBLIC_ADMIN_NAME=System Administrator
# Server-only — must NOT use NEXT_PUBLIC_*. If unset, the platform generates
# a random admin password on first boot and writes it to .seed-credentials.json
# inside the platform working directory. Either set it here or read it off
# the file once and rotate via the UI immediately after first login.
ADMIN_INITIAL_PASSWORD=REPLACE-with-strong-password
NEXT_PUBLIC_ORG_NAME=Your Organization
NEXT_PUBLIC_ORG_EMAIL=admin@your-org.org
NEXT_PUBLIC_ORG_COUNTRY=South Sudan

# --- Auth (server-side; required) ---
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE-with-48-byte-random-secret

# --- Postgres (optional — platform runs on PouchDB alone if unset) ---
# Use the compose service name `postgres` when running in the same stack.
# DATABASE_URL=postgresql://tamamhealth:PASSWORD@postgres:5432/safeguard_junub

# --- CouchDB sync ---
# false = pure local PouchDB (simplest prod setup).
# true  = live replication against a public CouchDB URL. See note below.
NEXT_PUBLIC_SYNC_ENABLED=false

# When sync is enabled, this MUST be a URL the BROWSER can reach —
# not the internal `http://couchdb:5984`. Put CouchDB behind nginx/Caddy
# with TLS and point to that public URL, e.g. https://couch.your-domain.org
# NEXT_PUBLIC_COUCHDB_URL=https://couch.your-domain.org

# Webhook signing secret for /api/sync (server-side).
# Generate: openssl rand -hex 32
# COUCHDB_WEBHOOK_SECRET=

# --- Server-side CouchDB access (for /api/* routes) ---
# docker-compose sets these automatically from the root .env. Override here
# only if running the platform outside the compose stack.
# COUCHDB_URL=http://couchdb:5984
# COUCHDB_ADMIN_USER=
# COUCHDB_ADMIN_PASSWORD=

# --- Email (optional) ---
# Pick the backend: "resend" | "sendgrid" | "smtp" | "" (disabled).
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# FROM_EMAIL=noreply@your-domain.org
# DEMO_FROM_EMAIL=noreply@your-domain.org
# DEMO_FROM_NAME=TamamHealth
# DEMO_NOTIFY_EMAIL=ops@your-domain.org

# --- Payments (optional) ---
# FLUTTERWAVE_SECRET_HASH=

# --- App URL (public URL users hit) ---
# NEXT_PUBLIC_APP_URL=https://app.your-domain.org

# --- Localization defaults ---
# 3-letter ISO 4217 currency code used as the default for ledger entries and
# payment links. Defaults to SSP.
# NEXT_PUBLIC_DEFAULT_CURRENCY=SSP

# Default 3-letter prefix used in patient hospital-number generation when a
# facility doesn't have its own `code` field. Defaults to TAB.
# NEXT_PUBLIC_HOSPITAL_NUMBER_DEFAULT_PREFIX=TAB

# Login screen subtitle/footer overrides. Defaults derive from
# NEXT_PUBLIC_ORG_COUNTRY ("Republic of <country> · Ministry of Health · v2.0").
# NEXT_PUBLIC_LOGIN_FOOTER=

# --- FHIR namespace ---
# Base URI used for FHIR identifier.system fields and CodeSystem/ValueSet `url`
# fields emitted by /api/terminology. Should be a domain you own.
# NEXT_PUBLIC_FHIR_NAMESPACE_BASE=https://terminology.your-domain.org

# --- DHIS2 export (optional) ---
# National health reporting endpoint. Server-side credentials may be set in
# addition to the public base URL when uploads require auth.
# NEXT_PUBLIC_DHIS2_BASE_URL=https://hmis.southsudan.health
# DHIS2_BASE_URL=https://hmis.southsudan.health      # server-side override
# DHIS2_USER=
# DHIS2_PASSWORD=
# DHIS2_PAT=                                          # personal access token alt to user/pass

# --- License (optional) ---
# HMAC secret + signed license key for offline license verification.
# TAMAMHEALTH_LICENSE_SECRET=
# TAMAMHEALTH_LICENSE_KEY=

# --- Observability / Sentry (recommended in production) ---
# Crash & performance reporting. The platform boots fine without these set,
# but in production we strongly recommend enabling Sentry for 5xx triage.
#
# SENTRY_DSN              — server DSN (server-only, never bundled).
# NEXT_PUBLIC_SENTRY_DSN  — browser DSN (baked into client bundle at build
#                           time; rebuild image to rotate).
# SENTRY_RELEASE          — release identifier for grouping events across
#                           deploys; recommended: $(git rev-parse --short HEAD).
#
# PII safety: every event is filtered through `stripPHI` (cookies + obvious
# patient-data keys are scrubbed before transport). See
# docs/operations/monitoring.md for the exact rule list and uptime monitor /
# PagerDuty alert thresholds.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_RELEASE=
