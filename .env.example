# =============================================================================
# TamamHealth — Docker Compose root environment template
# =============================================================================
# Copy to ./.env BEFORE running `docker compose up`:
#   cp .env.example .env
#
# Read by `docker compose` at the repo root. NOT used by platform/website at
# runtime — those have their own platform/.env.production and
# website/.env.production files. This file only holds the values compose
# interpolates into docker-compose.yml (CouchDB/Postgres credentials, ports,
# the analytics sync-worker secret, etc.).
#
# Every value below is referenced by docker-compose.yml with a ${VAR:?...}
# guard, so a missing value will fail `docker compose up` with a clear error.
# =============================================================================

# --- CouchDB credentials ---
# Required by: couchdb service, couchdb-backup service, sync-worker service.
# Generate strong values, e.g.:
#   openssl rand -base64 24 | tr -d '\n/+='
COUCHDB_USER=admin
COUCHDB_PASSWORD=REPLACE-with-strong-password

# HMAC signing secret shared between sync-worker and the platform's /api/sync
# webhook. Min 32 chars (enforced server-side). Required ONLY when running
# with `--profile analytics`. Generate:
#   openssl rand -hex 32
COUCHDB_WEBHOOK_SECRET=REPLACE-with-32-byte-hex-secret

# --- Postgres credentials (only used with `docker compose --profile analytics up`) ---
POSTGRES_USER=tamamhealth
POSTGRES_PASSWORD=REPLACE-with-strong-password
POSTGRES_DB=safeguard_junub

# --- Host port bindings ---
# Override only if another service is already listening on the default.
PLATFORM_PORT=3000
WEBSITE_PORT=3001
COUCHDB_PORT=5984
POSTGRES_PORT=5432

# --- Sync-worker tuning (optional) ---
# POLL_INTERVAL_MS=5000
# BATCH_SIZE=100

# --- GHCR image owner (optional) ---
# Used by the sync-worker image reference in docker-compose.yml. Defaults to
# `tamamhealth`. Override when running images published under a fork:
# GH_OWNER=tamamhealth

# --- Doppler (optional — secrets management) ---
# Set this to switch the platform container's entrypoint over to
# `doppler run -- npm start`. Unset = legacy env_file path. See
# docs/operations/secrets.md.
# DOPPLER_TOKEN=
