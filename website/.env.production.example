# =============================================================================
# TamamHealth Website — PRODUCTION environment template
# =============================================================================
# Copy to .env.production BEFORE running `docker compose build`:
#   cp website/.env.production.example website/.env.production
#
# All values below are optional — the marketing site renders fine with none of
# them set, but the public contact / demo-request / newsletter forms will fall
# back to a "thanks, we'll be in touch" no-op response with nothing actually
# delivered to your inbox until an email backend is configured.
# =============================================================================

# --- Public site URL (used in sitemap.xml + canonical tags) ---
# NEXT_PUBLIC_SITE_URL=https://tamamhealth.org

# --- Email backend ---
# Pick ONE provider (Resend or SendGrid). Leave both unset to disable email.
# Production setups should also set DEMO_FROM_EMAIL so the From: header on
# outbound mail isn't the provider's default sender.
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# DEMO_FROM_EMAIL=noreply@your-domain.org
# DEMO_FROM_NAME=TamamHealth Health

# Where form submissions are delivered (Contact, Demo Request, Newsletter
# subscribe notifications).
DEMO_NOTIFY_EMAIL=ops@your-domain.org

# --- Demo request scheduling (optional) ---
# When set, the demo-request confirmation page surfaces this link so the
# operator can self-book a call. Calendly / SavvyCal / Cal.com URL.
# DEMO_SCHEDULING_URL=https://calendly.com/your-link
