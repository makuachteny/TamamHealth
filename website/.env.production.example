# =============================================================================
# Tamam Website — PRODUCTION environment template
# =============================================================================
# Copy to .env.production BEFORE running `docker compose build`:
#   cp website/.env.production.example website/.env.production
#
# All values below are optional — the marketing site renders fine with none of
# them set, but the public contact / demo-request / newsletter forms will fall
# back to a "thanks, we'll be in touch" no-op response with nothing actually
# delivered to your inbox until an email backend is configured.
# =============================================================================

# --- Public site URL (used in sitemap.xml + canonical tags) ---
# NEXT_PUBLIC_SITE_URL=https://tamamhealth.org

# --- Email backend ---
# Pick ONE provider (Resend or SendGrid). Leave both unset to disable email.
# Production setups should also set DEMO_FROM_EMAIL so the From: header on
# outbound mail isn't the provider's default sender.
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# DEMO_FROM_EMAIL=support.tamam@gmail.com
# DEMO_FROM_NAME=Tamam

# Where form submissions are delivered (Contact, Demo Request, Newsletter
# subscribe notifications).
DEMO_NOTIFY_EMAIL=support.tamam@gmail.com

# --- Demo request scheduling (optional) ---
# Server-side Calendly API integration. Create a Calendly personal access token
# and use the Event Type URI for the appointment/demo event you want to expose.
# The site uses these to show availability and generate single-use booking links.
# CALENDLY_API_TOKEN=
# CALENDLY_EVENT_TYPE_URI=https://api.calendly.com/event_types/YOUR_EVENT_TYPE_UUID

# Optional: protect the Calendly webhook URL with a shared token.
# Configure the webhook URL in Calendly as:
# https://tamamhealth.org/api/calendly/webhook?token=YOUR_SECRET
# CALENDLY_WEBHOOK_TOKEN=

# Public fallback link shown when Calendly API credentials are not configured or
# when the API is temporarily unavailable.
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link
# NEXT_PUBLIC_DEMO_SCHEDULING_URL=https://calendly.com/your-link
